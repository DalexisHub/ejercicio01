<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Estudiantes</title>
</head>
<body>
    <h1>Lista de estudiantes</h1>

    <table border="1">
        <tr>
            <th>Nombre</th>
            <th>Nota</th>
        </tr>

        {{#each students}}
        <tr>
            <td>{{this.name}}</td>
            <td>
                {{#if (gt this.grade 15)}}
                    <strong style="color:green">{{this.grade}}</strong>
                {{else}}
                    {{this.grade}}
                {{/if}}
            </td>
        </tr>
        {{/each}}
    </table>

</body>
</html>